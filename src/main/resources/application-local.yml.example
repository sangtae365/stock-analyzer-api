# ────────────────────────────────────────────────────────
# 로컬 개발용 실제 키 설정 파일 예시
# 이 파일을 복사해서 application-local.yml 로 저장 후 실제 값 입력
# application-local.yml 은 .gitignore 에 등록되어 있으므로 커밋되지 않음
# ────────────────────────────────────────────────────────

kis:
  app-key: 여기에_실제_앱키_입력
  app-secret: 여기에_실제_앱시크릿_입력
